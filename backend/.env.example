# ============================================================
#  Maddad Backend – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ============================================================

# Runtime environment: development | production
ENVIRONMENT=development

# SQLite database file (recommended for local development – no installation needed).
# The file maddad.db is created automatically in the backend/ folder.
DATABASE_URL=sqlite:///./maddad.db

# Production example (PostgreSQL required):
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.rpxlvdwqdvelgvzkgvbh.supabase.co:5432/postgres

# Secret key used to sign JWT tokens (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-in-production

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS – comma-separated list of frontend origins, or * only for development
# Example: https://my-app.netlify.app,http://localhost:5500
CORS_ORIGINS=*
